# ResellAPI Backend Environment Configuration
# Copy this file to .env and configure your values

# ===========================================
# SERVER CONFIGURATION
# ===========================================
PORT=3001
NODE_ENV=development

# ===========================================
# FRONTEND CONFIGURATION
# ===========================================
# Frontend URL for CORS configuration
# Development: http://localhost:3000
# Production: https://your-frontend-domain.com
FRONTEND_URL=http://localhost:3000

# ===========================================
# DATABASE CONFIGURATION (Future)
# ===========================================
# Database connection string
# MongoDB: mongodb://localhost:27017/resellapi
# PostgreSQL: postgresql://username:password@localhost:5432/resellapi
# DATABASE_URL=mongodb://localhost:27017/resellapi

# ===========================================
# SECURITY CONFIGURATION
# ===========================================
# JWT Secret for authentication (if needed)
# JWT_SECRET=your-super-secret-jwt-key-here

# API Rate Limiting
# Maximum requests per window (default: 100)
RATE_LIMIT_MAX=100
# Rate limit window in milliseconds (default: 15 minutes)
RATE_LIMIT_WINDOW_MS=900000

# ===========================================
# ANALYTICS CONFIGURATION
# ===========================================
# Enable/disable analytics collection
ANALYTICS_ENABLED=true

# Data retention period in days (default: 90)
DATA_RETENTION_DAYS=90

# ===========================================
# GEOLOCATION CONFIGURATION
# ===========================================
# Enable/disable geolocation tracking
GEOLOCATION_ENABLED=true

# Fallback country if IP geolocation fails
FALLBACK_COUNTRY=United States

# ===========================================
# LOGGING CONFIGURATION
# ===========================================
# Log level: error, warn, info, debug
LOG_LEVEL=info

# Enable request logging
ENABLE_REQUEST_LOGGING=true

# ===========================================
# CORS CONFIGURATION
# ===========================================
# Additional allowed origins (comma-separated)
# ALLOWED_ORIGINS=https://admin.yourdomain.com,https://app.yourdomain.com

# ===========================================
# EXTERNAL SERVICES (Future)
# ===========================================
# Email service configuration
# EMAIL_SERVICE_API_KEY=your-email-service-key
# EMAIL_FROM=noreply@yourdomain.com

# SMS service configuration
# SMS_SERVICE_API_KEY=your-sms-service-key

# ===========================================
# MONITORING & HEALTH CHECKS
# ===========================================
# Health check endpoint
HEALTH_CHECK_PATH=/health

# Enable detailed health checks
DETAILED_HEALTH_CHECKS=true

# ===========================================
# DEVELOPMENT CONFIGURATION
# ===========================================
# Enable debug mode
DEBUG=false

# Enable API documentation
ENABLE_API_DOCS=true

# API documentation path
API_DOCS_PATH=/api-docs

# ===========================================
# PRODUCTION CONFIGURATION
# ===========================================
# Trust proxy (for reverse proxy setups)
# TRUST_PROXY=true

# Session secret for production
# SESSION_SECRET=your-super-secret-session-key

# ===========================================
# BACKUP & EXPORT CONFIGURATION
# ===========================================
# Enable data export functionality
ENABLE_DATA_EXPORT=true

# Export file format (csv, json, xlsx)
DEFAULT_EXPORT_FORMAT=csv

# Export file retention in days
EXPORT_RETENTION_DAYS=30

# ===========================================
# NOTIFICATION CONFIGURATION
# ===========================================
# Enable admin notifications
ENABLE_ADMIN_NOTIFICATIONS=false

# Admin notification email
# ADMIN_EMAIL=admin@yourdomain.com

# ===========================================
# CACHE CONFIGURATION (Future)
# ===========================================
# Redis connection string
# REDIS_URL=redis://localhost:6379

# Cache TTL in seconds
# CACHE_TTL=3600

# ===========================================
# EXAMPLE USAGE
# ===========================================
# 1. Copy this file: cp env.example .env
# 2. Update the values according to your setup
# 3. Never commit .env to version control
# 4. Use different .env files for different environments
#    - .env.development
#    - .env.staging
#    - .env.production
